{
  "name": "@rsbuild/plugin-typed-css-modules",
  "version": "1.2.4",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-typed-css-modules#readme",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-typed-css-modules",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-typed-css-modules/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "npx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.6",
    "@rsbuild/plugin-less": "^2.0.1",
    "@rsbuild/plugin-sass": "^1.5.3",
    "@rsbuild/plugin-stylus": "^2.0.1",
    "@rsbuild/plugin-type-check": "^1.5.0",
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.7.0",
    "@rstest/core": "^0.11.2",
    "@rstest/playwright": "^0.11.2",
    "@types/node": "^24.13.3",
    "line-diff": "2.1.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.13.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
